    {
      "module": "module.security",
      "mode": "managed",
      "type": "akamai_appsec_rate_policy",
      "name": "origin_error",
      "provider": "provider[\"registry.terraform.io/akamai/akamai\"]",
      "instances": [
        {
          "schema_version": 0,
          "attributes": {
            "config_id": 116230,
            "id": "116230:324887",
            "rate_policy": "{\"matchType\":\"path\",\"type\":\"WAF\",\"name\":\"Origin Error\",\"description\":\"An excessive error rate from the origin could indicate malicious activity by a bot scanning the site or a publishing error. In both cases, this would increase the origin traffic and could potentially destabilize it.\",\"averageThreshold\":5,\"burstThreshold\":8,\"clientIdentifiers\":[\"ip\"],\"useXForwardForHeaders\":false,\"requestType\":\"ForwardResponse\",\"sameActionOnIpv6\":true,\"pathMatchType\":\"Custom\",\"pathUriPositiveMatch\":true,\"additionalMatchOptions\":[{\"positiveMatch\":true,\"type\":\"ResponseStatusCondition\",\"values\":[\"400\",\"401\",\"402\",\"403\",\"404\",\"405\",\"406\",\"407\",\"408\",\"409\",\"410\",\"500\",\"501\",\"502\",\"503\",\"504\"]}],\"counterType\":\"per_edge\",\"penaltyBoxDuration\":\"TEN_MINUTES\"}",
            "rate_policy_id": 324887
          },
          "sensitive_attributes": [],
          "private": "bnVsbA==",
          "dependencies": [
            "module.security.akamai_appsec_configuration.config",
            "module.security.data.akamai_group.group"
          ]
        }
      ]
    },
    {
      "module": "module.security",
      "mode": "managed",
      "type": "akamai_appsec_rate_policy",
