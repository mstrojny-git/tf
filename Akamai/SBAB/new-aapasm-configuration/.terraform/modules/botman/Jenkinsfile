pipeline {
  agent any
  options { timestamps(); disableConcurrentBuilds() }
  environment {
    TARGET_BRANCH = 'tagging'  // change if needed
    TAG_PREFIX    = 'v'     // tags like v1.2.3
  }

  stages {
    stage('Test') {
      steps{
          checkout scm

            echo "Triggered from branch: ${env.BRANCH_NAME}"
      }
    }

    stage('PR: OPEN & UPDATE') {
      when {
        allOf {
          changeRequest()
          expression { return env.CHANGE_TARGET == 'main' }
        }
      }
      steps {
        sh 'echo "Ephemeral environment deploy for PR → target ${CHANGE_TARGET}"'
        sh 'echo "Ephemeral environment deploy for PR → target ${env.CHANGE_TARGET}"'
        // sh './scripts/deploy_preview.sh'
      }
    }

stage('Main Push') {
  when {
    allOf {
      branch 'main'
      not { changeRequest() }
    }
  }
  steps {
    sh 'echo "Direct push (or merge commit) to main"'
  }
}

stage('PR Merge') {
  wheåçn {
    allOf {
      branch 'main'
      expression {
        // Check if this commit is a merge commit (has 2 parents)
        def parents = sh(
          script: 'git rev-list --parents -n 1 "$GIT_COMMIT" | wc -w',
          returnStdout: true
        ).trim()
        return parents == '3'
      }
    }
  }
  steps {
    sh 'echo "Running post-merge tasks on main"'
  }
}

}
}
